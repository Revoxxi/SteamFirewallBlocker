#include "resource.h"

1 RT_MANIFEST "app.manifest"

IDD_HOTKEY_CAPTURE DIALOGEX 0, 0, 280, 90
STYLE DS_SETFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Set Hotkey"
FONT 9, "Segoe UI"
BEGIN
    LTEXT "Press the key combination you want to use.", IDC_HOTKEY_PROMPT, 12, 12, 256, 24
    DEFPUSHBUTTON "Cancel", IDCANCEL, 110, 58, 60, 20
END
